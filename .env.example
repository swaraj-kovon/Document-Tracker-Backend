# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co

# Service role key from Supabase Dashboard > Project Settings > API
SUPABASE_SERVICE_KEY=your-service-role-key

# ── URLs ────────────────────────────────────────────────────────────────────
# Full public URL where the backend API is reachable (no trailing slash)
BACKEND_URL=http://localhost:8001

# Full public URL where the frontend is reachable (no trailing slash)
FRONTEND_URL=http://localhost:3000

# ── JWT ─────────────────────────────────────────────────────────────────────
# JWT secret from Supabase Dashboard > Project Settings > API > JWT Secret
# This is used to verify Supabase-issued access tokens
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Admin Credentials ───────────────────────────────────────────────────────
# Email address of the bootstrap admin account (must end with @kovon.io)
ADMIN_EMAIL=founders@kovon.io

# Password for the bootstrap admin account
# The account is created/updated automatically on startup
ADMIN_PASSWORD=KovonAdmin@2026

# ── Email (Resend) ───────────────────────────────────────────────────────────
# API key from https://resend.com
RESEND_API_KEY=

# "From" address used in outgoing emails
SENDER_EMAIL=noreply@kovon.io
