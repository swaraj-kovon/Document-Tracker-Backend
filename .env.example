# ── MongoDB ─────────────────────────────────────────────────────────────────
# Connection string for your MongoDB instance
MONGO_URL=mongodb://localhost:27017

# Name of the MongoDB database to use
DB_NAME=kovon_document_tracker

# ── URLs ────────────────────────────────────────────────────────────────────
# Full public URL where the backend API is reachable (no trailing slash)
# Used to build email verification, approval, and file-serving links
BACKEND_URL=http://localhost:8001

# Full public URL where the frontend is reachable (no trailing slash)
# Used to build redirect links in emails (e.g. verify-email, reset-password)
FRONTEND_URL=http://localhost:3000

# ── JWT ─────────────────────────────────────────────────────────────────────
# Secret key used to sign and verify JWT access tokens
# MUST be changed to a long, random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=kovon_jwt_secret_change_me_in_production

# ── Admin Credentials ───────────────────────────────────────────────────────
# Email address of the bootstrap admin account (must end with @kovon.io)
ADMIN_EMAIL=founders@kovon.io

# Password for the bootstrap admin account
# The account is created/updated automatically on startup
ADMIN_PASSWORD=KovonAdmin@2026

# ── Email (Resend) ───────────────────────────────────────────────────────────
# API key from https://resend.com — required for sending verification,
# approval-request, and status-notification emails
RESEND_API_KEY=

# "From" address used in outgoing emails
# Must be a verified domain/address in your Resend account
SENDER_EMAIL=onboarding@resend.dev

# ── File Uploads ─────────────────────────────────────────────────────────────
# Directory where uploaded document files are stored.
# Can be an absolute path or relative to the backend/ folder.
# Defaults to ../uploads (i.e. kovon_document_tracker/uploads/) if not set.
UPLOADS_DIR=../uploads
